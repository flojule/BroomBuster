# Copy this file to .env and fill in only the sections you need.
# Neither block is required for basic usage — see README § Setup.

# ── Live GPS (only needed when USE_LIVE_GPS = True in main.py) ───────────
TRACCAR_URL=https://demo4.traccar.org
TRACCAR_USERNAME=you@example.com
TRACCAR_PASSWORD=your_traccar_password

# ── Email alerts (only needed when SEND_NOTIFICATION = True in main.py) ──
# Use a Gmail App Password — https://support.google.com/accounts/answer/185833
EMAIL_SENDER=you@gmail.com
EMAIL_RECEIVER=you@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
