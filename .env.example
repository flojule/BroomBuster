# Copy this file to .env and fill in only the sections you need.

# ── Docker Compose / production (required) ────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-generate-a-real-secret
REFRESH_SECRET=    # optional; defaults to JWT_SECRET + "-refresh"

# ── Optional: SQLite path override (default: /data/app.sqlite) ───────────────
# DB_PATH=/data/app.sqlite

# ── Preload region at boot (Pi warm-start) — avoids cold-first-request delay ──
# PRELOAD_REGION=bay_area

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO

# ── Dev mode — set to "true" to skip login on both API and frontend ───────────
# DEV_MODE=false

# ── Email alerts (only needed when SEND_NOTIFICATION = True in main.py) ──────
# Use a Gmail App Password — https://support.google.com/accounts/answer/185833
EMAIL_SENDER=you@gmail.com
EMAIL_RECEIVER=you@gmail.com
EMAIL_PASSWORD=your_gmail_app_password
